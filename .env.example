# Copy to `.env` and fill in. The app reads these at startup.

# --- LLM (optional in dev — pipeline runs rules-only without it) ---
OPENAI_API_KEY=

# Two model tiers per ASSIGNMENT.md.
#   dev     — fast, cheap; used by the classifier LLM fallback in development
#   premium — used by the eval rubric (gpt-4.1)
MODEL_DEV=gpt-4o-mini
MODEL_PREMIUM=gpt-4.1

# --- Pipeline ---
# Hard wall-clock cap for the whole request (safety + classifier + agent).
PIPELINE_TIMEOUT_S=12.0
# Per-classifier-LLM-call timeout (only triggered on rule miss).
CLASSIFIER_LLM_TIMEOUT_S=4.0
# Below this confidence, the rule cascade defers to the LLM (when available).
RULE_CONFIDENCE_THRESHOLD=0.7

# --- Classifier dedupe cache (stretch) ---
CLASSIFIER_CACHE_SIZE=256
CLASSIFIER_CACHE_TTL_S=300

# --- Session memory ---
SESSION_HISTORY_MAX_TURNS=10

# --- Market data ---
# `yfinance` (default) or `mock` for offline dev.
MARKET_DATA_PROVIDER=yfinance
